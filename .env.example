# Copy this file to .env and fill in real values. .env is git-ignored.
# Switch the front-end answer bot by changing CHAT_PROVIDER — the backend is unaffected.

# --- Front-end answer bot ---
# Options: perplexity | anthropic
CHAT_PROVIDER=perplexity

# --- Perplexity (Sonar) ---
PERPLEXITY_API_KEY=your-perplexity-api-key-here
PERPLEXITY_MODEL=sonar-pro
# Optional: lock Sonar's own web search to Montana sites (comma-separated hosts)
# PERPLEXITY_SEARCH_DOMAINS=mt.gov

# --- Anthropic / Claude (available for switch-back) ---
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-haiku-4-5

# --- Shared ---
CHAT_TOP_K=6
CHAT_CORS_ORIGIN=http://localhost:8000
